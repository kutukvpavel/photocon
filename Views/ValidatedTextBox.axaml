<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:photocon.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:photocon.Views"
        x:Class="photocon.Views.ValidatedTextBox">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,2,0" />
        </Style>
    </UserControl.Styles>

    <Grid HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition SharedSizeGroup="ValidatedLabel" Width="Auto"/>
            <ColumnDefinition SharedSizeGroup="ValidatedTb" Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="txtLabel" HorizontalAlignment="Right"/>
        <TextBox Grid.Column="1" x:Name="txtValue" HorizontalContentAlignment="Left"/>
    </Grid> 
</UserControl>