<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:photocon.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:photocon.Views"
        xmlns:app="using:photocon"
        x:Class="photocon.Views.ScanParamsEditor"
        x:DataType="m:ScanParams">

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,3,3,3" />
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Margin" Value="3,3,5,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

            <Grid ColumnDefinitions="auto,*" RowDefinitions="auto,auto,auto">
                <TextBlock Text="Scan Start (nm):"/><local:ValidatedTextBox Grid.Column="1" Grid.Row="0"
                    Value="{Binding Start, Mode=TwoWay}" FormatString="F0"/>
                <TextBlock Grid.Row="1" Text="Scan End (nm):"/><local:ValidatedTextBox Grid.Row="1" Grid.Column="1"
                    Value="{Binding End, Mode=TwoWay}" FormatString="F0"/>
                <TextBlock Grid.Row="2" Text="Speed (nm/min):"/><local:ValidatedTextBox Grid.Row="2" Grid.Column="1"
                    Value="{Binding Speed, Mode=TwoWay}" FormatString="F1"/>
            </Grid>

</UserControl>